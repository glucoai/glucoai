{
  "compilerOptions": {
    "target": "ES2020",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@gluco/ui": ["packages/ui/src"],
      "@gluco/ui/*": ["packages/ui/src/*"],
      "@gluco/tipos": ["packages/tipos/src"],
      "@gluco/tipos/*": ["packages/tipos/src/*"],
      "@gluco/utils": ["packages/utils/src"],
      "@gluco/utils/*": ["packages/utils/src/*"]
    }
  }
}
